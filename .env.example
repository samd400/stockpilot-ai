# StockPilot Microservices — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Must be SAME across ALL services (shared JWT secret)
SECRET_KEY=supersecretkey-stockpilot-change-in-production-32chars-minimum

# Shared service-to-service token
SERVICE_TOKEN=internal-service-secret-change-me

# Database (each service uses its own DB)
POSTGRES_PASSWORD=stockpilot123

# AI (Google Gemini)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyBB9AStpKhFG7J5bslp_9NPw5a85oGfecc

# Stripe (Europe / Global)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (India)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret

# PayTabs (GCC)
PAYTABS_SERVER_KEY=your-paytabs-server-key
PAYTABS_PROFILE_ID=your-paytabs-profile-id

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=StockPilot

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://app.yourdomain.com

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0

# India e-Invoice (NIC IRP)
NIC_CLIENT_ID=your-nic-client-id
NIC_CLIENT_SECRET=your-nic-client-secret
SUPPLIER_GSTIN=22AAAAA0000A1Z5

# Frontend
VITE_API_URL=http://localhost:80/api

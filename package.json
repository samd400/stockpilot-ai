{
  "name": "stockpilot",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev:web": "pnpm --filter @stockpilot/web dev",
    "dev:mobile": "pnpm --filter @stockpilot/mobile start",
    "build:web": "pnpm --filter @stockpilot/web build",
    "build:desktop": "pnpm --filter @stockpilot/desktop build",
    "build:sdk": "pnpm --filter @stockpilot/sdk build",
    "build:ui": "pnpm --filter @stockpilot/ui build",
    "build:all": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter e2e test",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.0.0"
}
